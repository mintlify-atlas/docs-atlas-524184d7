  "keyFeatures": [
    "JWT-based authentication with bcrypt password hashing",
    "CRUD for personalized workout routines with soft-delete",
    "Live training sessions with per-set weight/reps input and auto-save",
    "Catalog of 64 exercises with images and looping MP4 videos via AscendAPI",
    "Progress charts (weekly volume, max weight per exercise) powered by Chart.js",
    "Personal records (PRs) statistics endpoint",
    "Password recovery via email with Nodemailer and time-limited reset tokens",
    "User profile with avatar upload (Multer), biometric data (weight, height, age)",
    "Recommended routines seeded from scraped data (strengthlevel.es)",
    "Rest timer with countdown, sound, and vibration between sets",
    "Interactive onboarding tours for new feature discovery",
    "Rate limiting on auth endpoints and security headers via Helmet"
  ],
  "publicApiSurface": [
    "POST /api/auth/register",
